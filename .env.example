# Copy to `.env` in this directory (`.env` is gitignored).
# Grist loads the first existing file from: `process.cwd()/.env` or `../.env` next to `dist-electron/`.

# Default provider for new jobs (claude | codex | kimi | mock).
# If unset but Kimi URL or key is set below, defaults to kimi.
GRIST_DEFAULT_PROVIDER=kimi

# OpenAI-compatible endpoint (include `/v1` if your server uses that path prefix).
GRIST_KIMI_BASE_URL=http://127.0.0.1:8000/v1

# Secret your gateway expects (often as `Authorization: Bearer …`).
GRIST_KIMI_API_KEY=replace-me

GRIST_KIMI_MODEL=moonshotai/Kimi-K2.5

# Optional per-role overrides (otherwise same as default provider / DB settings).
# GRIST_PLANNER_PROVIDER=kimi
# GRIST_REDUCER_PROVIDER=kimi
# GRIST_VERIFIER_PROVIDER=kimi

# GRIST_ANTHROPIC_API_KEY=
# GRIST_OPENAI_API_KEY=
# GRIST_CLAUDE_MODEL=claude-sonnet-4-20250514
# GRIST_CODEX_MODEL=gpt-4.1
