{
  "name": "swarm-operator",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist-electron/main.js",
  "scripts": {
    "rebuild:electron": "electron-rebuild -f -w better-sqlite3",
    "dev": "concurrently -k \"vite --config frontend/vite.config.ts\" \"wait-on tcp:5173 && npm run build:electron && npm run rebuild:electron && electron .\"",
    "build:electron": "node scripts/build-electron.mjs",
    "build": "npm run build:electron && npx vite build --config frontend/vite.config.ts",
    "start": "npm run rebuild:electron && electron .",
    "pretest": "npm rebuild better-sqlite3",
    "test": "vitest run",
    "test:electron-smoke": "npm run build:electron && npx electron electron/smoke.cjs",
    "test:all": "npm test && npm run test:electron-smoke",
    "test:watch": "npm rebuild better-sqlite3 && vitest",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "better-sqlite3": "^11.8.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@electron/rebuild": "^3.7.2",
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.13.10",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.1.2",
    "electron": "^33.4.0",
    "esbuild": "^0.25.0",
    "postcss": "^8.5.3",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.8.2",
    "vite": "^6.2.1",
    "vitest": "^3.0.8",
    "wait-on": "^8.0.1"
  }
}
